<odoo>
    <record id="grades_course_action" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">grades.course</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="grades_course_lista_view" model="ir.ui.view">
        <field name="name">grades.course.list</field>
        <field name="model">grades.course</field>
        <field name="arch" type="xml">
            <list string="Courses">
                <field name="name" />
                <field name="student_qty" />
                <field name="grades_average" />
                <field name="description" />
                <field name="is_active" />
                <field name="course_start" />
                <field name="course_end" />
                <field name="last_evaluation_date" />
                <field name="course_shift" />
                <field name="teacher_id" />
                <field name="evaluation_ids" />
            </list>
        </field>
    </record>

    <record id="grades_course_form_view" model="ir.ui.view">
        <field name="name">grades.course.form</field>
        <field name="model">grades.course</field>
        <field name="arch" type="xml">
            <form string="Course">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': 1}" />
                </header>
                <sheet>
                    <group>
                        <group string="General">
                            <field name="name" required="1" />
                            <field name="description" />
                            <field name="course_start" required="1" />
                            <field name="course_end" required="1" />
                            <field name="teacher_id"
                                domain="['|', ('is_teacher', '=', True), ('is_freelance', '=', True)]"
                                options="{'no_create': True, 'no_create_edit': True}" required="1"
                                readonly="state != 'register'"
                                context="{'form_view_ref': 'grades_manager.teacher_form_view'}" />
                            <!--Se
                            le agrega store para que se pueda editar -->
                            <field name="teacher_email" string="Teacher Email" readonly="0" />
                        </group>
                        <group string="Evaluation">
                            <field name="course_image" />
                            <field name="student_qty" />
                            <field name="is_active" />
                            <field name="last_evaluation_date" readonly=" 1" />
                            <field name="course_shift" />
                            <field name="create_uid" invisible=" 1" />
                        </group>
                        <notebook>
                            <page string="Evaluations" name="evaluations">
                                <field name="evaluation_ids" readonly="state != 'register'" />
                            </page>
                            <page string="Students" name="students">
                                <field name="student_ids"
                                    domain="[('is_student', '=', True)]"
                                    options="{'no_create': True, 'no_create_edit': True}"
                                    readonly="state != 'register'"
                                    context="{'list_view_ref': 'grades_manager.student_list_view',
                                'form_view_ref': 'grades_manager.student_form_view'}" />
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
