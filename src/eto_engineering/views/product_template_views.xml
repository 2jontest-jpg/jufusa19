<odoo>
    <record id="view_product_template_form_engineering" model="ir.ui.view">
        <field name="name">product.template.form.engineering</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet/notebook" position="before">
                <group string="Engineering">
                    <field name="engineering_family_id"/>
                </group>
            </xpath>

        </field>
    </record>
</odoo>
