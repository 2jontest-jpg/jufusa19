<odoo>
    <record id="sale_order_form_inherit_engineering" model="ir.ui.view">
        <field name="name">sale.order.form.engineering</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Botón crear engineering -->
            <xpath expr="//header" position="inside">
                <button
                    name="action_create_engineering_design"
                    type="object"
                    string="Create Engineering Design"
                    class="btn-primary"/>
            </xpath>

            <!-- Smart button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_engineering_design"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-cogs">
                    <field name="engineering_design_count" widget="statinfo"
                           string="Engineering"/>
                </button>
            </xpath>

        </field>
    </record>
</odoo>
