<odoo>
    <record id="grades_evaluation_action" model="ir.actions.act_window">
        <field name="name">Evaluations</field>
        <field name="res_model">grades.evaluation</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="grades_evaluation_lista_view" model="ir.ui.view">
        <field name="name">grades.evaluation.list</field>
        <field name="model">grades.evaluation</field>
        <field name="arch" type="xml">
            <list string="Evaluations">
                <field name="name" />
                <field name="date" />
                <field name="observations" />
                <field name="course_id" />
            </list>
        </field>
    </record>
</odoo>
