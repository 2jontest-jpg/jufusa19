<odoo>

    <record id="sale_order_form_inherit_engineering" model="ir.ui.view">
        <field name="name">sale.order.form.engineering</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">

                <button
                    name="action_create_engineering_design"
                    type="object"
                    string="Create Engineering Design"
                    class="btn-primary"/>

            </xpath>

        </field>
    </record>

</odoo>
